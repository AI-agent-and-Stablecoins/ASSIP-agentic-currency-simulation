# Copy this file to .env and fill in real values. .env is gitignored and must never be committed.

# Persistence (Phase 1 default: local SQLite file, no setup required)
DATABASE_URL=sqlite:///./assip.db

# LLM routing (unused in Phase 1 -- rule-based agents make no LLM calls).
# project_instructions.md specifies src/llm/llm_router.py routes models through
# OpenRouter, so this single key is what Phase 2 actually needs.
OPENROUTER_API_KEY=

# Sandbox execution (unused in Phase 1's local-stub e2b wrapper)
E2B_API_KEY=

# Not yet wired into any code -- keeping the var name reserved for whenever it is.
WEIGHTS_AND_BIASES_API_KEY=
Polygon_API_KEY=
